@using BlazorApp.Models
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms

<EditForm Model="@newMember" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="mb-3">
        <label>First Name:</label>
        <InputText @bind-Value="newMember.FirstName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Last Name:</label>
        <InputText @bind-Value="newMember.LastName" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Email:</label>
        <InputText @bind-Value="newMember.Email" class="form-control" />
    </div>

    <div class="mb-3">
        <label>Role:</label>
        <InputText @bind-Value="newMember.Role" class="form-control" />
    </div>

    <button type="submit" class="btn btn-primary">Create Member</button>
</EditForm>

@code {
    private Member newMember = new();

    [Parameter] public EventCallback<Member> OnMemberCreated { get; set; }

    private async Task HandleValidSubmit()
    {
        await OnMemberCreated.InvokeAsync(newMember);
        newMember = new(); // reset form
    }
}
