@using BlazorApp.Interfaces
@using BlazorApp.Models
@using BlazorApp.Services
@using Microsoft.AspNetCore.Components
@using Microsoft.AspNetCore.Components.Forms

<EditForm Model="@newMember" OnValidSubmit="HandleValidSubmit">
    <DataAnnotationsValidator />
    <ValidationSummary />

    <div class="accordion mb-3" id="memberFormAccordion">
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingOne">
                <button class="accordion-button" type="button" data-bs-toggle="collapse" data-bs-target="#collapseOne"
                        aria-expanded="true" aria-controls="collapseOne">
                    Personal Information
                </button>
            </h2>
            <div id="collapseOne" class="accordion-collapse collapse show" aria-labelledby="headingOne"
                 data-bs-parent="#memberFormAccordion">
                <div class="accordion-body">
                    <div class="mb-3">
                        <label>First Name:</label>
                        <InputText @bind-Value="newMember.FirstName" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Last Name:</label>
                        <InputText @bind-Value="newMember.LastName" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Date of Birth:</label>
                        <InputDate @bind-Value="newMember.DateOfBirth" class="form-control w-auto" />
                    </div>
                    <div class="card mb-3 w-auto">
                        <div class="card-header w-auto">
                            Membership Details
                        </div>
                        <div class="card-body w-auto">
                            <!-- Child checkbox -->
                            <div class="form-check mb-3 w-auto">
                                <InputCheckbox @bind-Value="isChild" class="form-check-input" />
                                <label class="form-check-label">Child</label>
                            </div>

                            @if (isChild)
                            {
                                <div class="mb-3">
                                    <label>Parent First Name:</label>
                                    <InputText @bind-Value="newMember.ParentFirstName" class="form-control w-auto" />
                                </div>

                                <div class="mb-3">
                                    <label>Parent Last Name:</label>
                                    <InputText @bind-Value="newMember.ParentLastName" class="form-control w-auto" />
                                </div>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingTwo">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseTwo" aria-expanded="false" aria-controls="collapseTwo">
                    Address Information
                </button>
            </h2>
            <div id="collapseTwo" class="accordion-collapse collapse" aria-labelledby="headingTwo">
                <div class="accordion-body">
                    <div class="mb-3">
                        <label>Street:</label>
                        <InputText @bind-Value="newMember.Street" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Street Number:</label>
                        <InputText @bind-Value="newMember.StreetNumber" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>City:</label>
                        <InputText @bind-Value="newMember.City" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Country:</label>
                        <InputText @bind-Value="newMember.Country" class="form-control w-auto" />
                    </div>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingThree">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseThree" aria-expanded="false" aria-controls="collapseThree">
                    Contact Information
                </button>
            </h2>
            <div id="collapseThree" class="accordion-collapse collapse" aria-labelledby="headingThree">
                <div class="accordion-body">
                    <div class="mb-3">
                        <label>Phone Number:</label>
                        <InputText @bind-Value="newMember.PhoneNumber" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Email:</label>
                        <InputText @bind-Value="newMember.Email" class="form-control w-auto" />
                    </div>
                </div>
            </div>
        </div>
        <div class="accordion-item">
            <h2 class="accordion-header" id="headingFour">
                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse"
                        data-bs-target="#collapseFour" aria-expanded="false" aria-controls="collapseFour">
                    Trainee Information
                </button>
            </h2>
            <div id="collapseFour" class="accordion-collapse collapse" aria-labelledby="headingFour">
                <div class="accordion-body">
                    <div class="mb-3">
                        <label>Rank:</label>
                        <InputNumber @bind-Value="newMember.Rank" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Belt:</label>
                        <InputSelect @bind-Value="newMember.Belt" class="form-control w-auto">
                            <option value="White">White</option>
                            <option value="Black">Black</option>
                        </InputSelect>
                    </div>
                    <div class="mb-3">
                        <label>Role:</label>
                        <InputText @bind-Value="newMember.Role" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Date of Joining:</label>
                        <InputDate @bind-Value="newMember.DateOfJoining" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Aikido ID:</label>
                        <InputText @bind-Value="newMember.AikidoId" class="form-control w-auto" />
                    </div>
                    <div class="mb-3">
                        <label>Notes:</label>
                        <InputTextArea @bind-Value="newMember.NoteContent" class="form-control w-25" />
                    </div>
                </div>
            </div>
        </div>
    </div>

    <button type="submit" class="btn btn-primary mb-3">Create Member</button>
</EditForm>

@code {
    private Member newMember = new();
    private bool isChild = false;
    [Inject] private ICrudService<Member> MemberService { get; set; } = default!;
    [Parameter] public EventCallback<Member> OnMemberCreated { get; set; }

    private async Task HandleValidSubmit()
    {
        // Call API to create
        var created = await MemberService.CreateAsync(newMember);

        // Raise event so parent can update its list
        await OnMemberCreated.InvokeAsync(created);

        // Reset form
        newMember = new();
        isChild = false;
    }
}

